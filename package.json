{
  "name": "RupeeFlow",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "android:cleanbuild": "cd android && ./gradlew clean && cd .. && react-native run-android",
    "release-android": "cd android && ./gradlew assembleRelease -PenableAbiSplits=true && cd ..",
    "release-bundle": "cd android && ./gradlew bundleRelease -PenableAbiSplits=false && cd ..",
    "android:clean": "cd android && ./gradlew clean && cd ..",
    "lint": "eslint .",
    "start": "react-native start --client-logs",
    "test": "jest",
    "podinstall": "cd ios && pod install && cd ..",
    "bundle:analysis": "visualize-bundle",
    "bundle": "react-native-bundle-analyzer --platform android",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native/new-app-screen": "0.83.1",
    "@react-navigation/bottom-tabs": "^7.9.1",
    "@react-navigation/elements": "^2.9.4",
    "@react-navigation/native": "^7.1.27",
    "@react-navigation/native-stack": "^7.9.1",
    "dayjs": "^1.11.20",
    "lodash": "^4.17.21",
    "lucide-react-native": "^0.562.0",
    "nativewind": "^4.2.1",
    "react": "19.2.0",
    "react-hook-form": "^7.71.1",
    "react-native": "0.83.1",
    "react-native-device-info": "^15.0.2",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-markdown-display": "^7.0.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.19.0",
    "react-native-sqlite-storage": "6.0.1",
    "react-native-svg": "^15.15.1",
    "react-native-toast-message": "^2.3.3",
    "react-native-worklets": "latest",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.83.1",
    "@react-native/eslint-config": "0.83.1",
    "@react-native/metro-config": "0.83.1",
    "@react-native/typescript-config": "0.83.1",
    "@types/jest": "^29.5.13",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.0",
    "@types/react-native-sqlite-storage": "^6.0.5",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react-test-renderer": "19.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "visualize-bundle": "^1.4.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@3.6.4"
}
